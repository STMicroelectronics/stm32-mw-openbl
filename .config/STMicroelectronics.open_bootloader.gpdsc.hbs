<?xml version="1.0" encoding="UTF-8" standalone="no"?>
{{assign 'OpenBootloader_instance' (@root.SWConfigurationAPI.getInstances  "STMicroelectronics::USB:STM32CubeMX2 Config:OpenBootloader")~}}
{{#each @root.OpenBootloader_instance~}}
{{assign 'OpenBootloader_ctx' (@root.SWConfigurationAPI.getInstanceConfiguration this)~}}
<!-- ***************************************************************************
 * File Name   : {{@root.pdscAPI.getGPDSCFileName}}
 * Description : Generator PDSC File generated by the code generator
  ******************************************************************************
  * @attention
  *
  * Copyright (c) {{#unless (eq 2026 (toInt (year)))}}2026-{{/unless}}{{year}} STMicroelectronics.
  * All rights reserved.
  *
  * This software is licensed under terms that can be found in the mx_openbootloader_license.md file
  * in the same directory as the generated code.
  * If no mx_openbootloader_license.md file comes with this software, it is provided AS-IS.
  *
 ****************************************************************************** -->
{{/each}}
<package xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="1.0"
  xs:noNamespaceSchemaLocation="https://github.com/Open-CMSIS-Pack/Open-CMSIS-Pack-Spec/blob/main/schema/PACK.xsd">
  {{!--Dedicated Helper that provides the PDSC PackVendor--}}
  <vendor>{{@root.pdscAPI.getPackVendor}}</vendor>
  {{!--Dedicated Helper that provides the PDSC PackName--}}
  <name>{{@root.pdscAPI.getPackName}}</name>
  {{!--URL Tag, kept here since its required for valid schema parsing--}}
  <url>{{@root.pdscAPI.getPackURL}}</url>
  {{!--Release Section to update manually in case of new updated--}}
  <releases>
    <release version="0.0.1" date="2026-03-30">
      - First GPDSC OpenBootloader Model Release
    </release>
  </releases>
  <conditions>
{{~assign "conditions" (@root.pdscAPI.getAllPDSCConditionsWithFilters exclude="Use USART, Use I2C, Use I3C, Use SPI,
Use FDCAN, Use CAN, Use USB, Use Flash, Use Ram, Use OB, Use OTP, Use EEPROM, Use ENGI, Use RO, Use ICP, Use IWDG")}}
{{{@root.conditions}}}
  <condition id="Use USART">
  {{#if (@root.EnvVarAPI.getVariableValue 'USART_Protocol_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader USART Module" Csub="USART_Module"/>
    {{/if}}
    </condition>
  <condition id="Use I2C">
  {{#if (@root.EnvVarAPI.getVariableValue 'I2C_Protocol_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader I2C Module" Csub="I2C_Module"/>
    {{/if}}
    </condition>
  <condition id="Use I3C">
  {{#if (@root.EnvVarAPI.getVariableValue 'I3C_Protocol_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader I3C Module" Csub="I3C_Module"/>
    {{/if}}
    </condition>
  <condition id="Use SPI">
  {{#if (@root.EnvVarAPI.getVariableValue 'SPI_Protocol_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader SPI Module" Csub="SPI_Module"/>
    {{/if}}
    </condition>
  <condition id="Use FDCAN">
  {{#if (@root.EnvVarAPI.getVariableValue 'FDCAN_Protocol_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader FDCAN Module" Csub="FDCAN_Module"/>
    {{/if}}
    </condition>
  <condition id="Use USB">
  {{#if (@root.EnvVarAPI.getVariableValue 'USB_Protocol_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader USB Module" Csub="USB_Module"/>
    {{/if}}
    </condition>
  <condition id="Use CAN">
  {{#if (@root.EnvVarAPI.getVariableValue 'CAN_Protocol_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader CAN Module" Csub="CAN_Module"/>
    {{/if}}
    </condition>
  <condition id="Use FLASH">
  {{#if (@root.EnvVarAPI.getVariableValue 'Flash_Memory_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader Flash Module" Csub="Flash_Module"/>
  {{/if}}
  </condition>
  <condition id="Use RAM">
  {{#if (@root.EnvVarAPI.getVariableValue 'Ram_Memory_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader Ram Module" Csub="Ram_Module"/>
  {{/if}}
  </condition>
  <condition id="Use OB">
  {{#if (@root.EnvVarAPI.getVariableValue 'OB_Memory_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader OB Module" Csub="OB_Module"/>
  {{/if}}
  </condition>
  <condition id="Use EEPROM">
  {{#if (@root.EnvVarAPI.getVariableValue 'EEPROM_Memory_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader EEPROM Module" Csub="EEPROM_Module"/>
  {{/if}}
  </condition>
  <condition id="Use OTP">
  {{#if (@root.EnvVarAPI.getVariableValue 'Otp_Memory_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader OTP Module" Csub="OTP_Module"/>
  {{/if}}
  </condition>
  <condition id="Use ENGI">
  {{#if (@root.EnvVarAPI.getVariableValue 'ENGI_Memory_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader ENGI Bytes Module" Csub="ENGI_Module"/>
  {{/if}}
  </condition>
  <condition id="Use RO">
  {{#if (@root.EnvVarAPI.getVariableValue 'RO_Memory_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader RO Bytes Module" Csub="RO_Module"/>
  {{/if}}
  </condition>
  <condition id="Use ICP">
  {{#if (@root.EnvVarAPI.getVariableValue 'ICP_Memory_Class')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader ICP Module" Csub="ICP_Module"/>
  {{/if}}
  </condition>
  <condition id="Use IWDG">
  {{#if (@root.EnvVarAPI.getVariableValue 'HAL_IWDG_PROJECT_USE_HAL')}}
    <require Cclass="BOOTLOADER" Cgroup="OpenBootloader IWDG Module" Csub="IWDG_Module"/>
  {{/if}}
  </condition>
  </conditions>

  {{!-- This section will list all selected components with their descriptions, along with their generated files--}}
  <components>
    {{!-- This is a components data model constructed by the API, find below a snapshot for the return value--}}
   {{#each components}}
    <component {{{generatorId}}} {{{Cclass}}} {{{Cgroup}}} {{{Csub}}} {{{Cbundle}}} {{{Cvariant}}} {{{Cversion}}} {{{condition}}}>
      <description>{{description}}</description>
      <files>
        {{#each files_array}}
        <file category="{{category}}" name="{{gen_file}}" />
        {{/each}}
      </files>
    </component>
    {{/each}}
  </components>
</package>
